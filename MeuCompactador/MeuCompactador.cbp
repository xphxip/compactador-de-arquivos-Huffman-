			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="../huffman.h" />
		<Unit filename="../main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="../structures.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="../structures.h" />
		<Unit filename="../texto.txt" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
