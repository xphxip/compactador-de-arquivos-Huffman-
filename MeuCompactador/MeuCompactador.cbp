				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/MeuCompactador" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Unit filename="../Makefile" />
		<Unit filename="../compress.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="../compress.h" />
		<Unit filename="../decompress.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="../decompress.h" />
